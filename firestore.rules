rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "maxmin0925@gmail.com" && request.auth.token.email_verified == true);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Portfolio content is publicly readable and writable for this specific setup
    match /settings/portfolio {
      allow read, write: if true;
    }

    match /projects/{projectId} {
      allow read, write: if true;
    }

    // Legacy rules (optional but keeping for compatibility)
    match /profile/{docId} {
      allow read: if true;
      allow write: if true;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
